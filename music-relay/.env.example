PORT=8788
RELAY_API_KEY=change-me-long-random-secret

# Spotify (playlist import + optional server-side token fallback)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=

# Apple Music catalog (playlist import fallback if panel does not send Bearer)
APPLE_MUSIC_TEAM_ID=
APPLE_MUSIC_KEY_ID=
APPLE_MUSIC_PRIVATE_KEY=

# Deezer full-length (paste arl cookie from browser — deezer.com → DevTools → Application → Cookies)
DEEZER_ARL=

# Paths to CLI tools (must be on PATH if unset)
YT_DLP_PATH=yt-dlp
SPOTDL_PATH=spotdl
