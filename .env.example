# Production domain
NEXT_PUBLIC_APP_URL=https://nexlify.live

# Google Search Console — paste the verification meta content value (optional)
# GOOGLE_SITE_VERIFICATION=your-google-verification-token

JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
# AES-256-GCM for sensitive DB fields (auto-generated on VPS by ensure-security-env.sh)
ENCRYPTION_AT_REST_KEY=change-me-64-char-hex-or-long-random-string

DATABASE_URL="file:./dev.db"

# WHMCS billing (copy whmcs/modules/servers/streambilling/ into your WHMCS install)
WHMCS_API_SECRET=your-whmcs-module-api-secret
NEXT_PUBLIC_WHMCS_URL=https://billing.nexlify.live/cart.php

# 7-day free trial (server-side promo code; do not expose via NEXT_PUBLIC_*)
TRIAL_PROMO_CODE=XSTR-TRIAL-7DAY-NXLF

# Stripe (optional)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# IPTV panel license validation
PANEL_API_SECRET=your-panel-api-secret-here

ADMIN_EMAIL=admin@nexlify.live
ADMIN_PASSWORD=change-this-password

# Owner IPTV panel staging — test patches here before customer rollouts
PANEL_STAGING_URL=https://panel.nexlify.live/login
# Optional: lock panel.nexlify.live to your IP (comma-separated)
# PANEL_OWNER_IPS=your.public.ip.here

# IPTV panel live demo — https://panel.demo.nexlify.live/ (sandbox, read-only)
NEXT_PUBLIC_DEMO_PANEL_URL=https://panel.demo.nexlify.live/
# Server-only demo credentials (shown on /demo page HTML, not bundled in client JS)
DEMO_ADMIN_USER=admin
DEMO_ADMIN_PASSWORD=admin123
DEMO_RESELLER_USER=reseller
DEMO_RESELLER_PASSWORD=reseller123

# Privacy-friendly analytics (self-hosted Umami at stats.nexlify.live)
# NEXT_PUBLIC_UMAMI_URL=https://stats.nexlify.live
# NEXT_PUBLIC_UMAMI_WEBSITE_ID=your-website-uuid-from-umami-dashboard
