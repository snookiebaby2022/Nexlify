{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Nexlify: start dev",
      "type": "shell",
      "windows": {
        "command": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-dev.ps1"
      },
      "linux": {
        "command": "bash scripts/start-dev.sh"
      },
      "osx": {
        "command": "npm install && npm run dev"
      },
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    }
  ]
}
