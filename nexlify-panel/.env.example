DATABASE_URL="postgresql://nexlify:nexlify@localhost:5432/nexlify"
JWT_SECRET="change-me-to-a-long-random-string"
NEXT_PUBLIC_PANEL_NAME="Nexlify"
# Panel listen port (admin UI) — must match Admin → Settings → Server, then restart npm/pm2
PORT=3000
PANEL_PORT=3000
# Website / Xtream / M3U port for clients (often nginx on same host)
WEBSITE_PORT=3001
STREAM_HTTP_PORT=3001
NEXT_PUBLIC_SERVER_URL="http://localhost:3000"
NEXT_PUBLIC_WEBSITE_URL="http://localhost:3000"
# When IPTV uses a domain with TLS on :3000 (nginx terminates SSL, Next on localhost):
# PANEL_PRIMARY_DOMAIN="nexlify.live"
# PANEL_BEHIND_NGINX=1
# PANEL_BIND_HOST=127.0.0.1
# Required with nginx upstream nexlify_panel → 127.0.0.1:3000 (see scripts/ensure-panel-env.sh)
# PANEL_BIND_HOST=127.0.0.1
# PANEL_PUBLIC_PORT=3000
# PANEL_ASSUME_PROXY_SSL=1
# NEXT_PUBLIC_SERVER_URL="https://nexlify.live:3000"
# NEXT_PUBLIC_WEBSITE_URL="https://nexlify.live:3000"
# Then: ./scripts/install-nginx-panel-3000.sh
# Optional: panel git folder for updates (defaults to app cwd)
# PANEL_REPO_PATH="C:\Users\lizzi\nexlify-panel"
# Release notes feed for Admin → Updates (defaults to https://nexlify.live/api/panel-releases)
# NEXLIFY_RELEASES_URL="https://nexlify.live/api/panel-releases"
# Optional: sync with Admin → Settings → Domains & SSL (middleware host + HTTPS)
# PANEL_PRIMARY_DOMAIN="panel.nexlify.live"
# PANEL_EXTRA_DOMAINS="alias1.example.com,alias2.example.com"
# Public demo: skip license gate (or use NEXLIFY_LICENSE_SKIP=1)
# PANEL_DEMO_NO_LICENSE=1
# panel.demo.nexlify.live redirects to PANEL_PRIMARY_DOMAIN (see nginx/panel.demo.nexlify.live.conf)
# PANEL_FORCE_HTTPS="1"
# Comma-separated hosts/IPs allowed to load /_next/* in dev (public VPS IP, etc.)
ALLOWED_DEV_ORIGINS="85.17.162.54,localhost,127.0.0.1"
BILLING_WEBHOOK_SECRET="change-me-billing-webhook-secret"
# Root path allowed for folder import & watch folders (e.g. /media)
MEDIA_IMPORT_ROOT="/media"
# Scheduled jobs: call GET /api/cron (minute) and ?hourly=1 (every 6h), or run `npm run cron`
CRON_SECRET="change-me-cron-secret"
ESTIMATED_MBPS_PER_STREAM="4"
# Optional Redis cache (falls back to in-memory if unset)
REDIS_URL="redis://localhost:6379"
# Xtream/live: max requests per line+IP per minute
PLAYBACK_RATE_LIMIT_PER_MIN=120
# Admin stream probe timeout (ms); lower = faster checks
STREAM_PROBE_TIMEOUT_MS=2500
# Optional: auto-rotate agent tokens on servers not seen for N days (hourly cron). 0 = off
AGENT_TOKEN_ROTATE_DAYS=0
# Licensing — plans: 1m, 3m, 6m, 1y (vendor: npm run license:setup)
# Main server activation (all customer panels point here):
# NEXLIFY_LICENSE_API_URL=http://127.0.0.1:8787
# NEXLIFY_LICENSE_API_LOCAL=1
# NEXLIFY_LICENSE_COOKIE_SECURE=0
# NEXLIFY_LICENSE_REQUIRE_ONLINE=1
# NEXLIFY_LICENSE_KEY=
# NEXLIFY_LICENSE_PUBLIC_KEY=
# NEXLIFY_LICENSE_TRIAL_DAYS=14
# NEXLIFY_LICENSE_SKIP=1
# On MAIN server only (PM2 nexlify-license):
# LICENSE_SERVER_PORT=8787
# LICENSE_SERVER_API_SECRET=change-me-issue-secret
# LICENSE_SERVER_PRIVATE_PEM=  # or use .license-keys/private.pem
